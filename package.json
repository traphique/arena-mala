{
  "name": "arena-mala",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run kill:ports && concurrently \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite",
    "dev:api": "node server.js",
    "kill:ports": "sh -c 'PIDS=$(lsof -ti :4000 -ti :5173 -ti :5174 2>/dev/null); if [ -n \"$PIDS\" ]; then kill -9 $PIDS; fi'",
    "build": "vite build",
    "start": "NODE_ENV=production node server.js",
    "build:start": "npm run build && npm run start",
    "preview": "vite preview"
  },
  "dependencies": {
    "@radix-ui/react-tabs": "^1.1.13",
    "@supabase/supabase-js": "^2.98.0",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "file-type": "^21.3.0",
    "form-data": "^4.0.5",
    "lucide-react": "^1.8.0",
    "multer": "^2.0.2",
    "pe-library": "^2.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.19",
    "vite": "^7.1.3"
  }
}
