{
  "name": "arena-mala",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run kill:ports && concurrently \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite --port 5173 --strictPort",
    "dev:api": "node server.js",
    "kill:ports": "sh -c 'PIDS=$(lsof -ti :4000 -ti :5173 -ti :5174 2>/dev/null); if [ -n \"$PIDS\" ]; then kill -9 $PIDS; fi'",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "multer": "^2.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "vite": "^7.1.3"
  }
}
